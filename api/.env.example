# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://emyltvgrxkbyzvkygjjh.supabase.co
SUPABASE_SERVICE_KEY=           # Project Settings → API → service_role

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# REST API (used by @upstash/redis for caching)
UPSTASH_REDIS_REST_URL=         # https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=       # from Upstash dashboard

# TCP connection (used by BullMQ / ioredis)
UPSTASH_REDIS_HOST=             # xxx.upstash.io
UPSTASH_REDIS_PORT=6379
UPSTASH_REDIS_PASSWORD=         # same token as REST_TOKEN

# ── Anthropic (for AI summaries in worker) ────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://monumental-profiterole-b1e30f.netlify.app
