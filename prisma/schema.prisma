// ═══════════════════════════════════════════════════════════════════
// Prisma schema — Tasted
// DATABASE_URL = Supabase connection string (from Project Settings → Database)
// Format: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
// ═══════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")   // for migrations (bypasses pgBouncer)
}

model User {
  id           String    @id @db.Uuid
  display_name String
  avatar_url   String?
  is_premium   Boolean   @default(false)
  created_at   DateTime  @default(now()) @db.Timestamptz

  reviews       Review[]
  shopping_list ShoppingList[]
  followers     Follow[]  @relation("following")
  following     Follow[]  @relation("follower")

  @@map("users")
}

model Product {
  id                    String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  barcode               String?   @unique
  name                  String
  brand                 String?
  category              String?
  supermarket           String?
  image_url             String?
  ai_summary            String?
  ai_summary_updated_at DateTime? @db.Timestamptz
  created_at            DateTime  @default(now()) @db.Timestamptz

  // Performance columns (added in migration 002)
  score              Decimal?  @db.Decimal(3, 2)
  review_count       Int       @default(0)
  enrichment_status  String    @default("pending")
  scan_payload       Json?     // precomputed compact scan response

  reviews       Review[]
  shopping_list ShoppingList[]

  @@index([barcode])
  @@index([category])
  @@index([supermarket])
  @@index([enrichment_status])
  @@map("products")
}

model Review {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id        String?  @db.Uuid
  product_id     String   @db.Uuid
  taste_rating   Int?
  value_rating   Int?
  quality_rating Int?
  text           String?
  photo_url      String?
  is_anonymous   Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamptz

  user    User?    @relation(fields: [user_id],    references: [id])
  product Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([user_id])
  @@map("reviews")
}

model Follow {
  follower_id  String   @db.Uuid
  following_id String   @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz

  follower  User @relation("follower",  fields: [follower_id],  references: [id], onDelete: Cascade)
  following User @relation("following", fields: [following_id], references: [id], onDelete: Cascade)

  @@id([follower_id, following_id])
  @@map("follows")
}

model ShoppingList {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id      String   @db.Uuid
  product_id   String   @db.Uuid
  is_favourite Boolean  @default(false)
  is_checked   Boolean  @default(false)
  created_at   DateTime @default(now()) @db.Timestamptz

  user    User    @relation(fields: [user_id],    references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("shopping_list")
}
